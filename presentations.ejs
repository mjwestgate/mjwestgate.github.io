<div class="list">
<% for (const item of items) { %>
<div class="quarto-post" <%= metadataAttrs(item) %>>
  <br>
  <table>
    <tr>
      <td>
        <a href="<%- item.description %>">
          <img src="<%- item.image %>" alt="<%- item.title %>" class="thumbnail-image"/>
        </a>
      </td>
      <td>
        <h3 class="no-anchor listing-title">
          <a href="<%- item.description %>"><%- item.title %></a>
        </h3>
        <span class="text-muted listing-subtitle"><%= item.subtitle %></span>
        <p class="quarto-title-authors listing-author">
          <%- item.author %>. <%- item.date %>.
        </p>
      </td>
    </tr>
  </table>
</div>
<% } %>
</div>