<div class="list">
<% for (const item of items) { %>
<div <%= metadataAttrs(item) %>>
  <br>
  <table>
    <tr>
      <td>
        <a href="<%- item.description %>" target="_blank">
          <img src="<%- item.image %>" alt="<%- item.description %>" class="thumbnail-image"/>
        </a>
      </td>
      <td>
        <h5 class="listing-title"><%- item.title %></h5>
        <span class="text-muted listing-subtitle">
          <%= item.subtitle %>
        </span>
        <p class="quarto-title-authors listing-author">
          <%- item.date %>
        </p>
      </td>
    </tr>
  </table>
</div>
<% } %>
</div>